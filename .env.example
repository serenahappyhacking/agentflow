# AgentFlow 运维自动化引擎配置
# 复制为 .env 并填入真实值

AGENTFLOW_DEBUG=true
AGENTFLOW_DATABASE_URL=sqlite+aiosqlite:///./agentflow.db

# === 飞书 (Lark) ===
# 在飞书开放平台创建企业自建应用后获取
AGENTFLOW_LARK_APP_ID=cli_xxxx
AGENTFLOW_LARK_APP_SECRET=xxxx
AGENTFLOW_LARK_VERIFICATION_TOKEN=xxxx
AGENTFLOW_LARK_ENCRYPT_KEY=xxxx
# 飞书群机器人 webhook (用于发通知)
AGENTFLOW_LARK_WEBHOOK_NOTIFY=https://open.feishu.cn/open-apis/bot/v2/hook/xxxx
# 审批模板 code (在飞书管理后台创建审批模板后获取)
AGENTFLOW_LARK_APPROVAL_PIPELINE=approval_code_for_pipeline
AGENTFLOW_LARK_APPROVAL_RESOURCE=approval_code_for_resource
AGENTFLOW_LARK_APPROVAL_DOMAIN=approval_code_for_domain

# === 阿里云 ===
AGENTFLOW_ALI_ACCESS_KEY_ID=LTAI5xxxx
AGENTFLOW_ALI_ACCESS_KEY_SECRET=xxxx
AGENTFLOW_ALI_REGION_ID=cn-hangzhou
# 云效
AGENTFLOW_ALI_DEVOPS_ORG_ID=your_yunxiao_org_id
# ACR (容器镜像)
AGENTFLOW_ALI_ACR_REGISTRY=registry.cn-hangzhou.aliyuncs.com
AGENTFLOW_ALI_ACR_NAMESPACE=app
# ACK
AGENTFLOW_ALI_ACK_CLUSTER_ID=your_ack_cluster_id
# DNS
AGENTFLOW_ALI_DOMAIN_NAME=example.com
# VPC (资源开通时需要)
AGENTFLOW_ALI_VPC_ID=vpc-xxxx
AGENTFLOW_ALI_VSWITCH_ID=vsw-xxxx
AGENTFLOW_ALI_SECURITY_GROUP_ID=sg-xxxx

# === 华为云 (GPU 等) ===
AGENTFLOW_HW_ACCESS_KEY=xxxx
AGENTFLOW_HW_SECRET_KEY=xxxx
AGENTFLOW_HW_REGION=cn-north-4
AGENTFLOW_HW_PROJECT_ID=xxxx

# === 腾讯云 (少量资源) ===
AGENTFLOW_TC_SECRET_ID=xxxx
AGENTFLOW_TC_SECRET_KEY=xxxx
AGENTFLOW_TC_REGION=ap-beijing
